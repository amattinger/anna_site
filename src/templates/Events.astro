---
import Layout from '../layouts/Layout.astro';
import { type CollectionEntry } from 'astro:content';
import { EVENTS_IMAGES } from '../data/events-images';

interface Props {
  entry: CollectionEntry<'pages'>;
}

const { entry } = Astro.props;
const { title, description } = entry.data;
---

<Layout title={title} description={description}>
  <article class="events-page post-content">
    <header class="post-content-header">
      <h1 class="post-content-title">{title}</h1>
      {description && <p class="post-content-excerpt">{description}</p>}
    </header>

    <h2 class="events-gallery-title">Lunar New Year '26 @ Moongate Lounge — San Francisco Chamber of Commerce & Alaska Airlines</h2>

    <div class="events-gallery" role="region" aria-label="Event photos">
      <div class="events-gallery-strip">
        {EVENTS_IMAGES.map((src, i) => (
          <figure class="events-gallery-item">
            <img
              src={src}
              alt={`Event photo ${i + 1}`}
              loading={i < 4 ? 'eager' : 'lazy'}
              decoding="async"
              width={1200}
              height={675}
            />
          </figure>
        ))}
      </div>
    </div>
  </article>
</Layout>

<style>
  /* Override .post-content max-width so gallery can use full width */
  .events-page.post-content {
    max-width: none;
    width: 100%;
    padding-left: 0;
    padding-right: 0;
  }
  @media (min-width: 851px) {
    .events-page.post-content {
      margin-left: -3vw;
      margin-right: -3vw;
      width: calc(100% + 6vw);
    }
  }
  @media (max-width: 850px) {
    .events-page.post-content {
      margin-left: -6vw;
      margin-right: -6vw;
      width: calc(100% + 12vw);
    }
  }
  .events-page .post-content-header {
    margin-bottom: 2rem;
    padding-left: 3vw;
    padding-right: 3vw;
  }
  .events-gallery-title {
    text-align: center;
    font-size: 1.8rem;
    font-weight: 500;
    margin: 0 0 1.5rem;
    padding: 0 3vw;
    line-height: 1.35;
  }
  /* Horizontal scroll strip: images side by side, user scrolls. No JS. */
  .events-gallery {
    width: 94%;
    max-width: none;
    margin: 0 auto 2rem;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    background: color(var(--color-base) alpha(0.06));
    border-radius: 10px;
  }
  .events-gallery::-webkit-scrollbar {
    height: 8px;
  }
  .events-gallery::-webkit-scrollbar-track {
    background: color(var(--color-base) alpha(0.08));
    border-radius: 4px;
  }
  .events-gallery::-webkit-scrollbar-thumb {
    background: color(var(--color-base) alpha(0.25));
    border-radius: 4px;
  }
  .events-gallery-strip {
    display: flex;
    flex-direction: row;
    gap: 20px;
    padding: 0;
    width: max-content;
    min-height: 50vh;
    max-height: 70vh;
  }
  .events-gallery-item {
    flex: 0 0 auto;
    margin: 0;
    padding: 0;
    height: 60vh;
    min-height: 280px;
    display: block;
  }
  .events-gallery-item img {
    height: 100%;
    width: auto;
    max-width: none;
    display: block;
    object-fit: contain;
    vertical-align: bottom;
  }
</style>
