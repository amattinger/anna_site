---
import { getCollection, type CollectionEntry } from "astro:content";
import Page from "../templates/Page.astro";
import Contact from "../templates/Contact.astro";
import List from "../templates/List.astro";
import Events from "../templates/Events.astro";
import { WORK_ORDER } from "../data/work-order.ts";
import { BOUDOIR_FINE_ART_ORDER } from "../data/boudoir-fine-art-order.ts";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages
    .filter((entry) => entry.slug !== "index" && entry.slug !== "news" && entry.slug !== "sold")
    .map((entry) => {
      const templateKey = entry.data.templateKey;
      const baseSlug =
        templateKey === "work-page"
          ? "work"
          : templateKey === "boudoir-fine-art-page"
            ? "boudoir-fine-art"
            : "";
      const props = {
        entry,
        items: [] as CollectionEntry<"work">[],
        baseSlug,
      };
      return {
        params: { slug: entry.slug === "index" ? undefined : entry.slug },
        props,
      };
    });
}

const { entry, items: _pathItems, baseSlug } = Astro.props;
const templateKey = entry.data.templateKey;

// Static imports so Vite HMR reloads when work-order.ts / boudoir-fine-art-order.ts change
let items = _pathItems;
if (templateKey === "work-page") {
  const workEntries = await getCollection("work");
  const orderMap = new Map(WORK_ORDER.map((slug, i) => [slug, i]));
  items = workEntries
    .filter((e) => orderMap.has(e.slug))
    .sort((a, b) => (orderMap.get(a.slug) ?? 9999) - (orderMap.get(b.slug) ?? 9999));
} else if (templateKey === "boudoir-fine-art-page") {
  const workEntries = await getCollection("work");
  const orderMap = new Map(
    BOUDOIR_FINE_ART_ORDER.map((slug, i) => [slug, i])
  );
  items = workEntries
    .filter((e) => orderMap.has(e.slug))
    .sort((a, b) => (orderMap.get(a.slug) ?? 9999) - (orderMap.get(b.slug) ?? 9999));
}
---

{
  templateKey === "contact-page" ? (
    <Contact entry={entry} />
  ) : templateKey === "work-page" || templateKey === "boudoir-fine-art-page" ? (
    <List entry={entry} items={items} baseSlug={baseSlug} />
  ) : templateKey === "events-page" ? (
    <Events entry={entry} />
  ) : (
    <Page entry={entry} />
  )
}
